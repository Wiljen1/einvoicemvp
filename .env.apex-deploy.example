# Copy to .env.apex-deploy and fill only on your machine.
# Do not commit .env.apex-deploy.

APEX_WORKSPACE=EMEAWJ
APEX_SCHEMA=WKSP_EMEAWJ
APEX_APP_ID=56594
APEX_APP_SOURCE_DIR=apex/apps/f56594

# REST Enabled SQL is enabled and authenticated for this hosted workspace.
APEX_REST_SQL_URL=https://apex.oraclecorp.com/pls/apex/emeawj/_/sql
APEX_REST_SQL_USER=WKSP_EMEAWJ

# Choose exactly one local secret source:
# APEX_REST_SQL_PASSWORD=
# APEX_REST_SQL_PASSWORD_CMD=security find-generic-password -a "$USER" -s apex-rest-sql-wksp-emeawj -w
# APEX_REST_SQL_BEARER_TOKEN=
# APEX_REST_SQL_BEARER_TOKEN_CMD=

# SQLcl direct deployment requires an approved direct database connection.
# This is needed for no-browser APEX import/export/validate.
APEX_SQLCL_BIN=sql
# Optional if SQLcl is not on PATH:
# APEX_SQLCL_BIN_DIR=$HOME/sqlcl/sqlcl/bin
APEX_SQLCL_CONNECT=
APEX_SQLCL_USER=WKSP_EMEAWJ
# APEX_SQLCL_PASSWORD=
# APEX_SQLCL_PASSWORD_CMD=security find-generic-password -a "$USER" -s apex-sqlcl-wksp-emeawj -w
